{
  "name": "saascolegio-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "knex migrate:latest --knexfile src/infrastructure/database/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile src/infrastructure/database/knexfile.js",
    "db:seed": "knex seed:run --knexfile src/infrastructure/database/knexfile.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sentry/node": "^10.46.0",
    "bull": "^4.16.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.4.1",
    "fast-levenshtein": "^3.0.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "nodemailer": "^6.9.16",
    "p-limit": "^3.1.0",
    "papaparse": "^5.4.1",
    "pg": "^8.13.1",
    "puppeteer": "^23.11.1",
    "twilio": "^5.3.7",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup.js"
    ],
    "testMatch": [
      "<rootDir>/src/tests/**/*.test.js"
    ]
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
